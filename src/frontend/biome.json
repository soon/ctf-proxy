{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"ignore": [
			"dist/**",
			"package.json",
			"tsconfig.json",
			"public/manifest.json",
			".cta.json"
		],
		"include": ["src/**", ".vscode/*", "index.html", "vite.config.ts"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"include": ["src/routeTree.gen.ts", "src/client/**"],
			"linter": { "enabled": false },
			"organizeImports": { "enabled": false }
		}
	]
}
