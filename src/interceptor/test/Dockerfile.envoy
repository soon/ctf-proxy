FROM golang:1.24.5-alpine AS wasm-builder

RUN apk add --no-cache openssl

WORKDIR /build

COPY entrypoint.go interceptor_http.go interceptor_tcp.go helpers.go proto.go types.go utils.go go.mod go.sum ./
COPY test/test_interceptors.go ./main.go

RUN env GOOS=wasip1 GOARCH=wasm go build -buildmode=c-shared -o interceptor.wasm .

RUN mkdir -p /tls && openssl req -x509 -newkey rsa:2048 -nodes \
        -keyout /tls/key.pem -out /tls/cert.pem \
        -days 3650 -subj "/CN=localhost" && \
    chmod 644 /tls/key.pem /tls/cert.pem

FROM envoyproxy/envoy:v1.38.3

COPY test/envoy.yaml /etc/envoy/envoy.yaml
COPY --from=wasm-builder /build/interceptor.wasm /etc/envoy/wasm/interceptor.wasm
COPY --from=wasm-builder /tls/cert.pem /etc/envoy/tls/cert.pem
COPY --from=wasm-builder /tls/key.pem /etc/envoy/tls/key.pem

EXPOSE 15001 15002 15000

CMD ["envoy", "-c", "/etc/envoy/envoy.yaml", "-l", "info"]
